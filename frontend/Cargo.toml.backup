[package]
name = "frontend"
version = "0.1.0"
edition = "2021"

[dependencies]
web-sys = { version = "0.3", features = ["Window", "Document", "WebSocket", "MessageEvent", "HtmlInputElement", "Element", "KeyboardEvent", "MouseEvent"] }
wasm-bindgen = "0.2"
js-sys = "0.3"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
spacetimedb = { version = "1.0" }

[lib]
crate-type = ["cdylib"]

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
