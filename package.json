{
  "name": "checkboxes",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "cd backend && cargo build --target wasm32-unknown-unknown --release",
    "generate": "spacetime generate --lang typescript --out-dir ./generated --bin-path ./backend/target/wasm32-unknown-unknown/release/backend.wasm",
    "publish": "spacetime publish checkboxes --bin-path ./backend/target/wasm32-unknown-unknown/release/backend.wasm",
    "test:sync": "npx tsx test-websocket-sync.ts"
  },
  "devDependencies": {
    "spacetimedb": "^2.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
